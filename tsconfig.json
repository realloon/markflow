{
  "compilerOptions": {
    "moduleResolution": "bundler",
    "declaration": true,
    "rootDir": "src",
    "outDir": "dist",
    "exactOptionalPropertyTypes": true,
    "noUncheckedIndexedAccess": true,
    "verbatimModuleSyntax": true,
    "sourceMap": true,
    "declarationMap": false,
    "skipLibCheck": true
  },
  "include": ["src"]
}
